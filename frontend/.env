# Backend origin for API requests. Omit (empty) in dev to use the Vite proxy (/api -> localhost:8080).
# Example production build:
# VITE_API_BASE_URL=https://your-api.onrender.com
VITE_API_BASE_URL=

# Map geometry source: static (default) or api.
# static reads public/data/{STATE}.json and public/data/{STATE}-precincts.json.
# api reads /api/{STATE}/map?level=DISTRICT|PRECINCT first, then falls back to static files.
VITE_MAP_GEO_SOURCE=static
